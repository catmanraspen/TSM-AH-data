MASTER_DATA_FILE = "/home/catmanraspen/Documents/Programming/TSM_data/tbc_anniversary_market_history.csv"
REGION_ID = 26 # Anniversary EU Region

AUCTION_HOUSES = {
    559: ("Thunderstrike", "Alliance"),
