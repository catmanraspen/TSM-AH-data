token = get_token()
if token:
    # 1. Get Regional Data first
    regional_raw = scrape_region_data(token)
    
    if regional_raw:
        # Create the lookup with the correct key names found in your debug print
        region_lookup = {
            int(item['itemId']): {
                'regionMarketAvg': item.get('marketValue') or 0,
                'regionHistorical': item.get('historical') or 0,
                'regionSaleRate': item.get('saleRate') or 0,
                'regionSoldPerDay': item.get('soldPerDay') or 0
            } for item in regional_raw
        }

        batch_data = []
        for ah_id, (realm, faction) in AUCTION_HOUSES.items():
            ah_data = scrape_auction_house(token, ah_id, realm, faction)
            
            if ah_data:
                for item in ah_data:
                    # Match by Item ID
                    l_item_id = int(item['itemId'])
                    stats = region_lookup.get(l_item_id, {})
                    
                    # This "glues" the stats to your local AH item
                    item.update(stats)
                
                batch_data.extend(ah_data)
            time.sleep(2)

        if batch_data:
            append_to_storage(batch_data)

            timestamp_now = datetime.now().isoformat()
            update_last_run_log(timestamp_now)

    else:
        print("Failed to get regional data. Skipping this run.")
